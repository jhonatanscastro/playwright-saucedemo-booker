{
	"info": {
		"name": "Restful-Booker QA Challenge",
		"description": "Collection para validação de CRUD, Autenticação e Erros da API Restful-Booker.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Auth - Create Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code deve ser 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Token deve ser gerado e salvo\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('token');",
							"    pm.environment.set(\"token\", jsonData.token);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\" : \"admin\",\n    \"password\" : \"password123\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/auth", "host": ["{{base_url}}"], "path": ["auth"] }
			}
		},
		{
			"name": "Booking - Create Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Reserva criada com sucesso\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Validar dados da reserva\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.booking.firstname).to.eql(\"Jhonatan\");",
							"    pm.environment.set(\"bookingid\", jsonData.bookingid);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"firstname\" : \"Jhonatan\",\n    \"lastname\" : \"QA\",\n    \"totalprice\" : 150,\n    \"depositpaid\" : true,\n    \"bookingdates\" : {\n        \"checkin\" : \"2026-05-01\",\n        \"checkout\" : \"2026-05-10\"\n    },\n    \"additionalneeds\" : \"Breakfast\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/booking", "host": ["{{base_url}}"], "path": ["booking"] }
			}
		},
		{
			"name": "Booking - Delete Booking",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Exclusão confirmada (Status 201)\", function () {",
							"    pm.response.to.have.status(201);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [
					{ "key": "Cookie", "value": "token={{token}}", "type": "text" }
				],
				"url": { "raw": "{{base_url}}/booking/{{bookingid}}", "host": ["{{base_url}}"], "path": ["booking", "{{bookingid}}"] }
			}
		},
		{
			"name": "Booking - Error Validation (Missing Fields)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Deve retornar erro 500 para payload incompleto\", function () {",
							"    pm.response.to.have.status(500);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"firstname\" : \"Incompleto\"\n}",
					"options": { "raw": { "language": "json" } }
				},
				"url": { "raw": "{{base_url}}/booking", "host": ["{{base_url}}"], "path": ["booking"] }
			}
		}
	]
}